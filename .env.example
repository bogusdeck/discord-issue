# ─── BugBot (Vercel) ───────────────────────────────────────────

# Production Discord channel webhook
DISCORD_WEBHOOK_URL_PROD=https://discord.com/api/webhooks/YOUR_PROD_ID/YOUR_PROD_TOKEN

# Development / staging Discord channel webhook
DISCORD_WEBHOOK_URL_DEV=https://discord.com/api/webhooks/YOUR_DEV_ID/YOUR_DEV_TOKEN

# Shared secret — must match BUGBOT_SECRET in your Django .env
BOT_SECRET=change-me-to-a-long-random-string

# Your Django server origin (or * to allow all)
ALLOWED_ORIGIN=https://fasfas.in
