# ─── BugBot (Vercel) ───────────────────────────────────────────
# Discord channel webhook URL (from Server Settings → Integrations → Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_ID/YOUR_TOKEN

# Shared secret — must match BUGBOT_SECRET in your Django .env
BOT_SECRET=change-me-to-a-long-random-string

# Your Django server origin (or * to allow all)
ALLOWED_ORIGIN=https://yourdjango.app
